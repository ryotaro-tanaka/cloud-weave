{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "cloud-weave",
  "version": "0.2.0",
  "identifier": "com.ryotaro.cloudweave",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run ui:dev",
    "beforeBuildCommand": "npm run ui:build"
  },
  "app": {
    "windows": [
      {
        "title": "cloud-weave",
        "width": 800,
        "height": 600,
        "backgroundColor": "#141b28",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/open-cache/**"
        ]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": "^.+$"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/rclone"]
  }
}
