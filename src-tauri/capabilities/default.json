{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/rclone",
          "sidecar": true,
          "args": [
            "listremotes",
            "--json",
            "--config",
            {
              "validator": "\\S+"
            }
          ]
        },
        {
          "name": "binaries/rclone",
          "sidecar": true,
          "args": [
            "lsjson",
            {
              "validator": "[A-Za-z0-9_-]+:"
            },
            "-R",
            "--files-only",
            "--exclude",
            {
              "validator": "\\S+"
            },
            "--config",
            {
              "validator": "\\S+"
            }
          ]
        },
        {
          "name": "binaries/rclone",
          "sidecar": true,
          "args": [
            "config",
            "show",
            "--config",
            {
              "validator": "\\S+"
            }
          ]
        },
        {
          "name": "binaries/rclone",
          "sidecar": true,
          "args": [
            "config",
            "create",
            {
              "validator": "[A-Za-z0-9_-]+"
            },
            "onedrive",
            {
              "validator": "[A-Za-z0-9_=.\\-/+:]+"
            },
            {
              "validator": "[A-Za-z0-9_=.\\-/+:]+"
            },
            {
              "validator": "[A-Za-z0-9_=.\\-/+:]+"
            },
            "--config",
            {
              "validator": "\\S+"
            }
          ]
        },
        {
          "name": "binaries/rclone",
          "sidecar": true,
          "args": [
            "config",
            "reconnect",
            {
              "validator": "[A-Za-z0-9_-]+:"
            },
            "--config",
            {
              "validator": "\\S+"
            }
          ]
        },
        {
          "name": "binaries/rclone",
          "sidecar": true,
          "args": [
            "config",
            "delete",
            {
              "validator": "[A-Za-z0-9_-]+"
            },
            "--config",
            {
              "validator": "\\S+"
            }
          ]
        }
      ]
    }
  ]
}
