{
  "name": "cloud-weave",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": "24.14.x"
  },
  "scripts": {
    "ui:dev": "vite",
    "ui:build": "tsc -b && vite build",
    "brand:icons": "tauri icon assets/brand/cloud-weave-logo.png -o src-tauri/icons",
    "test:run": "vitest run",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all --check",
    "rust:test:logic": "cargo test --manifest-path src-tauri/crates/rclone_logic/Cargo.toml",
    "pr:check": "npm run rust:fmt && npm run rust:fmt:check && npm run rust:test:logic && npm run test:run && npm run ui:build",
    "dev": "tauri dev",
    "demo": "node ./scripts/run-demo.mjs",
    "build": "tauri build",
    "setup:rclone": "powershell -ExecutionPolicy Bypass -File .\\scripts\\download-rclone.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
